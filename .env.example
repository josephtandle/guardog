# Copy this file to .env and fill in your keys
# Only VIRUSTOTAL_API_KEY is needed — everything else is optional

# VirusTotal (highly recommended — free tier is plenty for everyday use)
# Sign up: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=your_api_key_here

# Telegram alerts — sends a message when a BARK (dangerous) package is detected
# Get a bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# GitHub (optional — increases rate limits for reputation checks)
GITHUB_API_TOKEN=your_github_token_here
